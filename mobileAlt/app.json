{
  "expo": {
    "name": "Axiom",
    "slug": "axiom-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "scheme": "axiom",
    "updates": {
      "url": "https://u.expo.dev/f9c4fa25-f804-4a57-abfe-5db4a8bfcf72",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Axiom uses your photo library to analyze meals and estimate calories.",
          "cameraPermission": "Axiom uses your camera to take photos of meals for calorie estimation."
        }
      ],
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#000000",
          "sounds": [],
          "mode": "production"
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.axiomtraining.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Axiom uses your camera to take photos of meals for calorie estimation.",
        "NSPhotoLibraryUsageDescription": "Axiom uses your photo library to analyze meals and estimate calories.",
        "NSUserTrackingUsageDescription": "We use anonymous analytics to improve your Axiom experience and show you relevant features.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.axiom.mobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "axiom"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": []
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f9c4fa25-f804-4a57-abfe-5db4a8bfcf72"
      }
    },
    "owner": "axiomtraining"
  }
}
