generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String            @id @default(uuid())
  heightCm            Float?
  weightKg            Float?
  bodyCompTag         String?
  trainingAge         String?
  equipment           String?
  constraintsText     String?
  createdAt           DateTime          @default(now())
  name                String?
  email               String?           @unique
  hashedPassword      String?
  googleId            String?           @unique
  dateOfBirth         DateTime?
  tier                String            @default("free")
  stripeCustomerId    String?
  stripeSubStatus     String?
  dailyAnalysisCount  Int               @default(0)
  dailyAnalysisDate   DateTime?
  dailyPhotoScanCount Int               @default(0)
  dailyPhotoScanDate  String?
  coachThreadId       String?
  savedProgram        String?
  coachGoal           String?
  coachBudget         String?
  coachOnboardingDone Boolean           @default(false)
  updatedAt           DateTime          @default(now()) @updatedAt
  coachProfile        String?
  programStartDate    DateTime?
  expoPushToken       String?
  currentStreak       Int               @default(0)
  longestStreak       Int               @default(0)
  lastWorkoutDate     String?
  bodyWeightLogs      BodyWeightLog[]
  mealEntries         MealEntry[]
  nutritionLogs       NutritionLog[]
  sessions            Session[]
  wellnessCheckins    WellnessCheckin[]
  workoutLogs         WorkoutLog[]
}

model NutritionLog {
  id        String   @id @default(uuid())
  userId    String
  date      String
  proteinG  Float
  carbsG    Float
  fatG      Float
  calories  Float    @default(0)
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model MealEntry {
  id        String   @id @default(uuid())
  userId    String
  date      String
  name      String
  mealType  String   @default("meal")
  calories  Float    @default(0)
  proteinG  Float    @default(0)
  carbsG    Float    @default(0)
  fatG      Float    @default(0)
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model BodyWeightLog {
  id        String   @id @default(uuid())
  userId    String
  date      String
  weightLbs Float
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model WellnessCheckin {
  id         String   @id @default(uuid())
  userId     String
  date       String
  mood       Int
  energy     Int
  sleepHours Float
  stress     Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model Session {
  id           String              @id @default(uuid())
  userId       String?
  selectedLift String
  goal         String?
  threadId     String?
  isPublic     Boolean             @default(false)
  createdAt    DateTime            @default(now())
  messages     DiagnosticMessage[]
  snapshots    ExerciseSnapshot[]
  plans        GeneratedPlan[]
  user         User?               @relation(fields: [userId], references: [id])
}

model VideoCache {
  id         String   @id @default(uuid())
  exerciseId String   @unique
  videoId    String
  title      String
  thumbnail  String
  fetchedAt  DateTime @default(now())
}

model ExerciseSnapshot {
  id         String   @id @default(uuid())
  sessionId  String
  exerciseId String
  weight     Float
  sets       Int
  repsSchema String
  rpeOrRir   String?
  createdAt  DateTime @default(now())
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model DiagnosticMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String
  message   String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model GeneratedPlan {
  id        String   @id @default(uuid())
  sessionId String
  planJson  String
  planText  String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model WorkoutLog {
  id        String   @id @default(uuid())
  userId    String
  date      String
  title     String?
  exercises String
  notes     String?
  duration  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model KnowledgeChunk {
  id         String   @id @default(uuid())
  source     String
  chapter    String?
  content    String
  embedding  String
  tokenCount Int      @default(0)
  createdAt  DateTime @default(now())
}

model ExerciseNormalization {
  rawName       String   @id
  canonicalName String
  category      String
  primaryMuscle String
  isCompound    Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Affiliate {
  id                String                  @id @default(uuid())
  name              String
  email             String                  @unique
  promoCodeId       String?                 @unique  // Stripe promo_xxx
  stripeAccountId   String?                 @unique  // Stripe acct_xxx
  onboarded         Boolean                 @default(false)
  createdAt         DateTime                @default(now())
  subscriptions     AffiliateSubscription[]
  payouts           AffiliatePayout[]
}

model AffiliateSubscription {
  subscriptionId String    @id                       // Stripe sub_xxx
  affiliateId    String
  createdAt      DateTime  @default(now())
  affiliate      Affiliate @relation(fields: [affiliateId], references: [id])
}

model AffiliatePayout {
  id               String    @id @default(uuid())
  affiliateId      String
  stripeTransferId String?
  amountCents      Int
  currency         String    @default("cad")
  sourceEventId    String    @unique               // idempotency
  createdAt        DateTime  @default(now())
  affiliate        Affiliate @relation(fields: [affiliateId], references: [id])
}
