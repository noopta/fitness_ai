generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String            @id @default(uuid())
  heightCm            Float?
  weightKg            Float?
  bodyCompTag         String?
  trainingAge         String?
  equipment           String?
  constraintsText     String?
  createdAt           DateTime          @default(now())
  name                String?
  email               String?           @unique
  hashedPassword      String?
  googleId            String?           @unique
  appleId             String?           @unique
  dateOfBirth         DateTime?
  tier                        String            @default("free")
  stripeCustomerId            String?
  stripeSubStatus             String?
  appleOriginalTransactionId  String?           @unique
  // Google Play subscription tracking. purchaseToken is the long opaque string
  // returned by Play Billing; productId pins the SKU so renewals can be matched
  // against the right plan if we ever sell multiple products.
  googlePurchaseToken         String?           @unique
  googleProductId             String?
  googleSubExpiresAt          DateTime?
  dailyAnalysisCount  Int               @default(0)
  dailyAnalysisDate   DateTime?
  dailyPhotoScanCount Int               @default(0)
  dailyPhotoScanDate  String?
  // Agentic Anakin per-day usage (cost control). Mirrors the analysis
  // counter pattern. agentic-main only; additive.
  agentTurnsCount     Int               @default(0)
  agentTurnsDate      DateTime?
  coachThreadId       String?
  savedProgram        String?
  coachGoal           String?
  coachBudget         String?
  coachOnboardingDone Boolean           @default(false)
  updatedAt           DateTime          @default(now()) @updatedAt
  coachProfile        String?
  programStartDate    DateTime?
  expoPushToken       String?
  reengagementOptOut  Boolean           @default(false)
  lastActiveAt        DateTime?
  lastWorkoutNudgeAt  DateTime?
  lastNutritionNudgeAt DateTime?
  lastInactivityNudgeAt DateTime?
  currentStreak       Int               @default(0)
  longestStreak       Int               @default(0)
  lastWorkoutDate     String?
  // Nutrition logging streak — separate from workout streak so loss-aversion
  // signals are clear about *which* habit is at risk.
  nutritionStreak           Int      @default(0)
  longestNutritionStreak    Int      @default(0)
  lastNutritionLogDate      String?
  // Streak protection: 1 freeze granted per 7 logged days of either kind, max 2.
  // Consumed on a single-day miss before resetting the streak.
  streakFreezes             Int      @default(0)
  // Personalize at-risk push timing — exponentially-smoothed hour-of-day (0-23 EST)
  typicalWorkoutLogHour     Int?
  typicalNutritionLogHour   Int?
  // Subtract workout calorie burn from the day's calorie target. Default on.
  // Users whose nutrition plan already assumes a high activity multiplier can
  // turn this off in Settings to avoid double-counting their training.
  subtractWorkoutBurnFromCalories Boolean @default(true)
  // Track when we last sent each kind of streak-reinforcement notification so
  // we don't spam the user (one per kind per day max).
  lastStreakAtRiskAt        DateTime?
  lastSurpriseRewardAt      DateTime?
  username            String?           @unique
  avatarBase64        String?
  dailyCalorieTarget  Float?            // user-declared calorie target (overrides TDEE-computed)
  bodyWeightLogs           BodyWeightLog[]
  mealEntries              MealEntry[]
  savedFoods               SavedFood[]
  nutritionLogs            NutritionLog[]
  sessions                 Session[]
  wellnessCheckins         WellnessCheckin[]
  workoutLogs              WorkoutLog[]
  activityLogs             ActivityLog[]
  // Social
  sentFriendRequests       Friendship[]          @relation("SentRequests")
  receivedFriendRequests   Friendship[]          @relation("ReceivedRequests")
  conversationsAsA         DirectConversation[]  @relation("ConversationsAsA")
  conversationsAsB         DirectConversation[]  @relation("ConversationsAsB")
  sentMessages             Message[]             @relation("SentMessages")
  sharedByMe               SharedItem[]          @relation("SharedByMe")
  sharedWithMe             SharedItem[]          @relation("SharedWithMe")
  postReactions            PostReaction[]        @relation("UserReactions")
  postComments             PostComment[]         @relation("UserComments")
  invitesSent              UserInvite[]          @relation("InvitesSent")
  inviteUsed               UserInvite?           @relation("InviteUsed")
  feedViews                UserFeedView[]
  savedArticles            SavedArticle[]
  agentMemory              AgentMemory?
  agentConversation        AgentConversation?
  // Group chats (#4)
  groupsCreated            GroupChat[]    @relation("GroupCreator")
  groupMemberships         GroupMember[]  @relation("GroupMemberships")
  groupMessagesSent        GroupMessage[] @relation("GroupMessagesSent")
  // Finished-programs archive — populated when a program is replaced by a new
  // one (or when the user explicitly archives), so users can see their full
  // training history with stats.
  completedPrograms        CompletedProgram[]
  referredByCode           String?
  // Institution
  institutionMemberships   InstitutionMember[]
}

model NutritionLog {
  id        String   @id @default(uuid())
  userId    String
  date      String
  proteinG  Float
  carbsG    Float
  fatG      Float
  calories  Float    @default(0)
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@index([userId, createdAt])
}

model MealEntry {
  id        String   @id @default(uuid())
  userId    String
  date      String
  name      String
  mealType  String   @default("meal")
  calories  Float    @default(0)
  proteinG  Float    @default(0)
  carbsG    Float    @default(0)
  fatG      Float    @default(0)
  ingredientsJson String?
  tagsJson        String?
  nutrientsJson   String?
  source          String   @default("manual")
  parseConfidence String?
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, date])
}

model SavedFood {
  id              String   @id @default(uuid())
  userId          String
  name            String
  normalizedName  String
  calories        Float    @default(0)
  proteinG        Float    @default(0)
  carbsG          Float    @default(0)
  fatG            Float    @default(0)
  ingredientsJson String?
  tagsJson        String?
  nutrientsJson   String?
  source          String   @default("manual")
  useCount        Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId, useCount])
}

model BodyWeightLog {
  id        String   @id @default(uuid())
  userId    String
  date      String
  weightLbs Float
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, date])
}

model WellnessCheckin {
  id         String   @id @default(uuid())
  userId     String
  date       String
  mood       Int
  energy     Int
  sleepHours Float
  stress     Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@index([userId, createdAt])
}

model Session {
  id           String              @id @default(uuid())
  userId       String?
  selectedLift String
  goal         String?
  threadId     String?
  isPublic     Boolean             @default(false)
  createdAt    DateTime            @default(now())
  messages     DiagnosticMessage[]
  snapshots    ExerciseSnapshot[]
  plans        GeneratedPlan[]
  user         User?               @relation(fields: [userId], references: [id])
}

model VideoCache {
  id         String   @id @default(uuid())
  exerciseId String   @unique
  videoId    String
  title      String
  thumbnail  String
  fetchedAt  DateTime @default(now())
}

model ExerciseSnapshot {
  id         String   @id @default(uuid())
  sessionId  String
  exerciseId String
  weight     Float
  sets       Int
  repsSchema String
  rpeOrRir   String?
  createdAt  DateTime @default(now())
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model DiagnosticMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String
  message   String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model GeneratedPlan {
  id        String   @id @default(uuid())
  sessionId String
  planJson  String
  planText  String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// A user's prior training program, archived when they start a new one (or
// when the program completes). Lets users browse their full history with
// the inputs they chose, the goal they pursued, and how they actually did.
// `stats` is a JSON blob computed at archive time (workouts logged, total
// volume, body-weight change, days active, etc.) so the screen can render
// without re-querying every related log.
model CompletedProgram {
  id             String   @id @default(uuid())
  userId         String
  programJson    String   // the saved program at archival
  startDate      DateTime
  endDate        DateTime @default(now())
  goal           String?
  durationWeeks  Int?
  daysPerWeek    Int?
  stats          String?  // JSON: { workoutsLogged, totalVolumeLb, bodyWeightStart, ... }
  reason         String?  // 'replaced' | 'completed' — why it was archived
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, endDate])
}

model WorkoutLog {
  id        String   @id @default(uuid())
  userId    String
  date      String
  title     String?
  exercises String
  notes     String?
  duration  Int?
  // Estimated kcal burned for the session. Computed server-side at log time
  // from exercises + the user's bodyweight (MET × kg × hours). Nullable so
  // pre-migration rows stay valid.
  caloriesBurnedKcal Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  // Hot read paths: strength-profile, agent read_recent_workouts, today's
  // burn computation, history. All scope by userId and order/window on
  // date or createdAt. Without these the queries were full table scans.
  @@index([userId, date])
  @@index([userId, createdAt])
}

model KnowledgeChunk {
  id         String   @id @default(uuid())
  source     String
  chapter    String?
  content    String
  embedding  String
  tokenCount Int      @default(0)
  createdAt  DateTime @default(now())
}

model ExerciseNormalization {
  rawName       String   @id
  canonicalName String
  category      String
  primaryMuscle String
  isCompound    Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Affiliate {
  id              String                @id @default(uuid())
  name            String
  email           String                @unique
  referralCode    String                @unique   // e.g. "JAAFAR30" — used in ?ref= links
  stripeAccountId String?               @unique   // Stripe Connect acct_xxx
  onboarded       Boolean               @default(false)  // completed Stripe Connect onboarding
  active          Boolean               @default(false)  // admin activates after onboarding
  commissionRate  Float                 @default(0.30)   // 30% of original price
  discountRate    Float                 @default(0.20)   // 20% off for referred users
  inviteToken     String?               @unique   // one-time setup link token
  inviteUsedAt    DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @default(now()) @updatedAt
  commissions     AffiliateCommission[]
  payouts         AffiliatePayout[]
}

model AffiliateCommission {
  id                   String           @id @default(uuid())
  affiliateId          String
  stripeSubscriptionId String
  stripeInvoiceId      String           @unique   // idempotency — one commission per invoice
  stripeCustomerId     String
  originalAmountCents  Int              // price before discount
  commissionCents      Int              // 30% of original
  currency             String           @default("cad")
  status               String           @default("pending")  // pending | paid | cancelled
  payoutId             String?
  createdAt            DateTime         @default(now())
  affiliate            Affiliate        @relation(fields: [affiliateId], references: [id])
  payout               AffiliatePayout? @relation(fields: [payoutId], references: [id])
}

model AffiliatePayout {
  id               String                @id @default(uuid())
  affiliateId      String
  stripeTransferId String?               @unique
  totalCents       Int
  currency         String                @default("cad")
  periodStart      DateTime
  periodEnd        DateTime
  status           String                @default("pending")  // pending | completed | failed
  createdAt        DateTime              @default(now())
  affiliate        Affiliate             @relation(fields: [affiliateId], references: [id])
  commissions      AffiliateCommission[]
}

// ─── Social ───────────────────────────────────────────────────────────────────

model Friendship {
  id          String   @id @default(uuid())
  requesterId String
  addresseeId String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  requester   User     @relation("SentRequests",     fields: [requesterId], references: [id])
  addressee   User     @relation("ReceivedRequests", fields: [addresseeId], references: [id])
  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
}

model DirectConversation {
  id             String    @id @default(uuid())
  participantAId String
  participantBId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt
  participantA   User      @relation("ConversationsAsA", fields: [participantAId], references: [id])
  participantB   User      @relation("ConversationsAsB", fields: [participantBId], references: [id])
  messages       Message[]
  @@unique([participantAId, participantBId])
}

model Message {
  id             String             @id @default(uuid())
  conversationId String
  senderId       String
  body           String
  readAt         DateTime?
  createdAt      DateTime           @default(now())
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User               @relation("SentMessages", fields: [senderId], references: [id])
  @@index([conversationId, createdAt])
}

model SharedItem {
  id          String   @id @default(uuid())
  sharerId    String
  recipientId String
  itemType    String
  itemId      String?
  payload     String
  caption     String?
  createdAt   DateTime @default(now())
  sharer      User     @relation("SharedByMe",   fields: [sharerId],    references: [id])
  recipient   User     @relation("SharedWithMe", fields: [recipientId], references: [id])
  reactions   PostReaction[]
  comments    PostComment[]
  @@index([recipientId, createdAt])
}

model PostReaction {
  id        String     @id @default(uuid())
  postId    String
  userId    String
  type      String     @default("heart")
  createdAt DateTime   @default(now())
  post      SharedItem @relation(fields: [postId],  references: [id], onDelete: Cascade)
  user      User       @relation("UserReactions", fields: [userId], references: [id])
  @@unique([postId, userId])
}

model PostComment {
  id        String     @id @default(uuid())
  postId    String
  authorId  String
  text      String
  createdAt DateTime   @default(now())
  post      SharedItem @relation(fields: [postId],   references: [id], onDelete: Cascade)
  author    User       @relation("UserComments", fields: [authorId], references: [id])
}

model UserInvite {
  code         String   @id @default(uuid())
  inviterId    String
  usedByUserId String?  @unique
  createdAt    DateTime @default(now())
  usedAt       DateTime?
  inviter      User     @relation("InvitesSent", fields: [inviterId],     references: [id])
  usedBy       User?    @relation("InviteUsed",  fields: [usedByUserId],  references: [id])
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  date      String   // YYYY-MM-DD
  type      String   // "workout" | "nutrition" | "wellness" | "analysis"
  count     Int      @default(1)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, type])
  @@index([userId, date])
}

// ─── Institution ──────────────────────────────────────────────────────────────

model Institution {
  id        String              @id @default(uuid())
  name      String
  slug      String              @unique
  logoUrl   String?
  active    Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @default(now()) @updatedAt
  members   InstitutionMember[]
  invites   InstitutionInvite[]
}

model InstitutionMember {
  id            String      @id @default(uuid())
  institutionId String
  userId        String
  role          String      @default("athlete")
  active        Boolean     @default(true)
  joinedAt      DateTime    @default(now())
  institution   Institution @relation(fields: [institutionId], references: [id])
  user          User        @relation(fields: [userId],        references: [id])
  @@unique([institutionId, userId])
  @@index([userId])
}

model InstitutionInvite {
  id              String      @id @default(uuid())
  institutionId   String
  invitedByUserId String
  email           String?
  role            String      @default("athlete")
  token           String      @unique @default(uuid())
  expiresAt       DateTime
  usedAt          DateTime?
  usedByUserId    String?
  createdAt       DateTime    @default(now())
  institution     Institution @relation(fields: [institutionId], references: [id])
}

// ─── Research / Article Feed Items ───────────────────────────────────────────

model FeedItem {
  id          String    @id @default(uuid())
  externalId  String    @unique  // PMID or article URL (dedup key)
  type        String             // "research" | "article"
  title       String
  summary     String             // GPT-generated plain-English summary
  url         String
  source      String             // "PubMed", "Harvard Health", etc.
  tags        String             // JSON array e.g. ["strength","fat_loss"]
  publishedAt DateTime?
  fetchedAt   DateTime  @default(now())
  views       UserFeedView[]
  saves       SavedArticle[]

  @@index([fetchedAt])
}

// Per-user view tracking so the feed doesn't re-show the same articles on every
// pull-to-refresh. The feed endpoint records a view when an item is returned to
// the user, and getFeedItemsForTags filters them out.
model UserFeedView {
  id         String   @id @default(uuid())
  userId     String
  feedItemId String
  viewedAt   DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedItem   FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)

  @@unique([userId, feedItemId])
  @@index([userId, viewedAt])
}

// User-saved (bookmarked) articles surfaced from the feed.
model SavedArticle {
  id         String   @id @default(uuid())
  userId     String
  feedItemId String
  savedAt    DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedItem   FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)

  @@unique([userId, feedItemId])
  @@index([userId, savedAt])
}

// ─── Agentic Anakin (agentic-main branch) ──────────────────────────────────
// Durable cross-session memory for the agent. One row per user holding a
// JSON array of free-form notes the agent maintains (goals, preferences,
// flagged constraints like "knee pain on squats"). Kept separate from
// coachProfile so the agent owns its own memory surface.
//
// SAFE/ADDITIVE: enabling this in an environment requires `prisma db push`
// (or a migration). It is gated behind the AGENT_ENABLED flag and is never
// touched while the flag is off, so production is unaffected until a
// deliberate cutover.
model AgentMemory {
  id        String   @id @default(uuid())
  userId    String   @unique
  notesJson String   @default("[]")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Rolling per-user agent conversation (text transcript only — tool round-
// trips are ephemeral per turn). Gives the agent multi-turn continuity
// without the client managing history. Trimmed to a recent window in code.
model AgentConversation {
  id           String   @id @default(uuid())
  userId       String   @unique
  messagesJson String   @default("[]")
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Group Chats (#4: social groupchats + Anakin accountability) ───────────
// Lightweight messaging between users with an opt-in "Anakin drops by every
// morning" accountability layer. Each member can share their workout goal;
// the group itself can also have a shared goal Anakin tracks.

model GroupChat {
  id                 String         @id @default(uuid())
  name               String
  groupGoal          String?        // optional shared group goal
  anakinDailyEnabled Boolean        @default(false)  // opt-in daily check-in
  createdAt          DateTime       @default(now())
  createdById        String
  createdBy          User           @relation("GroupCreator", fields: [createdById], references: [id])
  members            GroupMember[]
  messages           GroupMessage[]
}

model GroupMember {
  id       String    @id @default(uuid())
  groupId  String
  userId   String
  goal     String?   // each member's shared workout goal
  joinedAt DateTime  @default(now())
  group    GroupChat @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User      @relation("GroupMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

model GroupMessage {
  id        String    @id @default(uuid())
  groupId   String
  senderId  String?   // null = Anakin (system / accountability post)
  text      String
  createdAt DateTime  @default(now())
  group     GroupChat @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User?     @relation("GroupMessagesSent", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([groupId, createdAt])
}
